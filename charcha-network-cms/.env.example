# ─────────────────────────────────────────────────────────
# Charcha Network CMS — Environment Variables
# Copy this file to .env.local
# ─────────────────────────────────────────────────────────

# Optional: browser title / metadata
# NEXT_PUBLIC_SITE_NAME=Charcha Network
# NEXT_PUBLIC_SITE_DESCRIPTION=Editorial CMS

# Charcha API base URL (must include /api). Proxied in dev via next.config rewrites.
#
# "localhost" = THIS computer only — not a VPS, not production, no public internet.
# contentflow-backend runs on port 4500. The CMS proxies /api/* to it.
# If your backend uses another port, change the number here and restart `npm run dev`.
#
# Start that backend before login — otherwise Internal Server Error / ECONNREFUSED in the dev terminal.
NEXT_PUBLIC_CHARCHA_API_URL=http://localhost:4500/api

# (Optional) Public CMS app URL for absolute links / OG meta
# NEXT_PUBLIC_APP_URL=https://cms.yoursite.com

# Public news site domain for reader URLs when NEXT_PUBLIC_WEBSITE_URL is not set (production)
# NEXT_PUBLIC_WEBSITE_DOMAIN=news.yoursite.com

# Reader “View article” — this app serves /article/[slug] on the same Next dev server.
# Default base in code is http://localhost:3000; if Next runs on another port (e.g. 3002), set:
# NEXT_PUBLIC_WEBSITE_URL=http://localhost:3002
# NEXT_PUBLIC_WEBSITE_ARTICLE_PATH=article
