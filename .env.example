# ─────────────────────────────────────────────────────────
# ContentFlow Frontend (repository root) — Environment Variables
# Copy this file to .env.local and fill in the values.
#
# Charcha Network CMS lives in ./charcha-network-cms/ — it does not read this
# file. Use charcha-network-cms/.env.example and NEXT_PUBLIC_CHARCHA_API_URL.
# ─────────────────────────────────────────────────────────

# URL of the ContentFlow backend API.
# In development, the Next.js dev server proxies /api/* to this address.
# Start contentflow-backend on port 4500 before npm run dev, or requests will fail.
# In production, set this to your deployed backend URL.
NEXT_PUBLIC_API_URL=http://localhost:4500/api

# (Optional) Override the public-facing app URL for absolute links / OG meta.
# NEXT_PUBLIC_APP_URL=https://app.yoursite.com

# Default website domain for publishing articles (default: adtech365.com).
# NEXT_PUBLIC_WEBSITE_DOMAIN=adtech365.com

# Reader / “View article” links. This app serves /article/[slug] on the same Next dev server (default base http://localhost:3000).
# If Next runs on another port (e.g. 3002), set:
# NEXT_PUBLIC_WEBSITE_URL=http://localhost:3002
# Example: http://localhost:3000/article/my-slug/

# Reader article path segment (default: article → …/article/my-slug).
# NEXT_PUBLIC_WEBSITE_ARTICLE_PATH=article
