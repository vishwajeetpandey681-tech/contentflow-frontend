# ─────────────────────────────────────────────────────────
# ContentFlow Frontend — Environment Variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────

# URL of the ContentFlow backend API.
# In development, the Next.js dev server proxies /api/* to this address.
# In production, set this to your deployed backend URL.
NEXT_PUBLIC_API_URL=http://localhost:4500/api

# (Optional) Override the public-facing app URL for absolute links / OG meta.
# NEXT_PUBLIC_APP_URL=https://app.yoursite.com
